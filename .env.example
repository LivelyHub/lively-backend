# Database (per CORE.md)
DATABASE_URL=            # Neon Postgres connection string — DO NOT COMMIT the real one
# Local fallback (docker compose up db): postgresql://postgres:postgres@localhost:5433/lively_dev

# Service auth (per CORE.md)
BOT_SERVICE_KEY=         # shared secret lively-bot sends as a header, not a user session
JWT_SECRET=               # signs family-member session tokens for lively-mobile

# Server
PORT=                     # e.g. 3000

# Meta WhatsApp Cloud API webhook verification (GET /webhook handshake)
WHATSAPP_VERIFY_TOKEN=    # arbitrary secret; must match the Verify Token field in the Meta developer console
META_APP_SECRET=          # Meta app dashboard -> App settings -> Basic -> App secret; verifies X-Hub-Signature-256 on POST /webhook

# Meta WhatsApp Cloud API outbound send (replies to inbound messages)
WHATSAPP_ACCESS_TOKEN=    # Meta dashboard -> WhatsApp -> API Setup -> access token (use a permanent System User token, the temp one dies in 24h)
WHATSAPP_PHONE_NUMBER_ID= # Meta dashboard -> WhatsApp -> API Setup -> Phone number ID (numeric id, NOT the phone number)
GRAPH_API_VERSION=        # optional, defaults to v23.0

# AI reply service (lively-bot's POST /reply; authed with BOT_SERVICE_KEY)
BOT_REPLY_URL=            # e.g. http://localhost:3000 or the deployed lively-bot base URL
